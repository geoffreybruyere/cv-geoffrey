            </span>
            <!-- ChatGPT -->
            <span class="ai-logo" data-name="ChatGPT">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.998 5.998 0 0 0-3.998 2.9 6.042 6.042 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
            </span>
            <!-- Gemini -->
            <span class="ai-logo" data-name="Gemini">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.04 19.32Q12 21.51 12 24q0-2.49.93-4.68.96-2.19 2.58-3.81t3.81-2.55Q21.51 12 24 12q-2.49 0-4.68-.93a12.3 12.3 0 0 1-3.81-2.58 12.3 12.3 0 0 1-2.58-3.81Q12 2.49 12 0q0 2.49-.96 4.68-.93 2.19-2.55 3.81a12.3 12.3 0 0 1-3.81 2.58Q2.49 12 0 12q2.49 0 4.68.96 2.19.93 3.81 2.55t2.55 3.81"/></svg>
            </span>
            <!-- Notion -->
            <span class="ai-logo" data-name="Notion">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.981-.7-2.055-.607L3.01 2.295c-.466.046-.56.28-.374.466zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.935-.56.935-1.167V6.354c0-.606-.233-.933-.748-.887l-15.177.887c-.56.047-.747.327-.747.933zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.748 0-.935-.234-1.495-.933l-4.577-7.186v6.952L12.21 19s0 .84-1.168.84l-3.222.186c-.093-.186 0-.653.327-.746l.84-.233V9.854L7.822 9.76c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.139c-.093-.514.28-.887.747-.933zM1.936 1.035l13.31-.98c1.634-.14 2.055-.047 3.082.7l4.249 2.986c.7.513.934.653.934 1.213v16.378c0 1.026-.373 1.634-1.68 1.726l-15.458.934c-.98.047-1.448-.093-1.962-.747l-3.129-4.06c-.56-.747-.793-1.306-.793-1.96V2.667c0-.839.374-1.54 1.447-1.632z"/></svg>
            </span>
            <!-- Figma -->
            <span class="ai-logo" data-name="Figma">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 24c2.2 0 4-1.8 4-4v-4H8c-2.2 0-4 1.8-4 4s1.8 4 4 4m0-12c-2.2 0-4 1.8-4 4s1.8 4 4 4h4v-8zm0-8C5.8 4 4 5.8 4 8s1.8 4 4 4h4V4zm8 0h-4v8h4c2.2 0 4-1.8 4-4s-1.8-4-4-4m0 12c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4"/></svg>
            </span>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {rightCards.map((card) => (
            <div class="skill-flip">
              <div class="skill-flip-inner">
                <div class="skill-flip-front">
                  <span class="rounded-sm px-2.5 py-1 text-[13px] font-light text-text-body" style="border: 0.5px solid var(--color-border);">
                    {card.front}
                  </span>
                </div>
                <div class="skill-flip-back rounded-sm px-2.5 py-1">
                  {card.back}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ai-logo {
    position: relative;
    display: inline-flex;
    align-items: center;
    color: var(--color-text-secondary);
    opacity: 0.3;
    transition: opacity 0.2s ease, transform 0.2s ease;
    cursor: default;
  }
  .ai-logo:hover {
    opacity: 0.7;
    transform: translateY(-2px);
  }
  /* Tooltip */
  .ai-logo::after {
    content: attr(data-name);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) scale(0.9);
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    color: var(--color-bg-primary);
    background: var(--color-text-primary);
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }
  .ai-logo:hover::after {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }

  .skill-flip {
    perspective: 600px;
    display: inline-block;
    cursor: pointer;
  }

  .skill-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hover flip on pointer devices */
  @media (hover: hover) {
    .skill-flip:hover .skill-flip-inner {
      transform: rotateY(180deg);
    }
  }

  /* Tap flip on touch */
  .skill-flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .skill-flip-front,
  .skill-flip-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .skill-flip-front {
    position: relative;
  }

  .skill-flip-back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
    background: var(--color-text-secondary);
    color: var(--color-bg-primary);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 6px;
  }
</style>

<script>
  import { inView } from "motion";

  const cols = document.querySelectorAll<HTMLElement>(".comp-col");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced && cols.length) {
    cols.forEach((col) => {
      col.style.opacity = "0";
      col.style.transform = "translateY(20px)";
      col.style.transition = "opacity 0.6s ease, transform 0.6s ease";
    });

    inView("#competences-cols", () => {
      cols.forEach((col, i) => {
        setTimeout(() => {
          col.style.opacity = "1";
          col.style.transform = "translateY(0)";
        }, i * 100);
      });
    }, { amount: 0.2 });
  }

  // Touch: toggle flip on tap
  if (window.matchMedia("(pointer: coarse)").matches) {
    document.querySelectorAll<HTMLElement>(".skill-flip-inner").forEach((inner) => {
      inner.parentElement?.addEventListener("click", () => {
        inner.classList.toggle("flipped");
      });
    });
  }
</script>
