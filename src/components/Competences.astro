---
import type { Translations } from "../i18n/fr";

interface Props {
  t: Translations["competences"];
}

const { t } = Astro.props;
const leftCards = t.col1;
const rightCards = t.col2;
---

<section id="competences" style="scroll-margin-top: 70px;">
  <!-- Separator -->
  <div class="mx-auto max-w-[768px] px-8 max-md:px-6">
    <div class="h-px bg-border" />
  </div>

  <div class="mx-auto max-w-[768px] px-8 max-md:px-6 py-10">
    <h2 class="sr-only">{t.srTitre}</h2>

    <div aria-hidden="true" class="mb-6 text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-dark">
      {t.titre}
    </div>

    <div class="grid grid-cols-2 gap-8 max-md:grid-cols-1" id="competences-cols">
      <!-- Left column -->
      <div class="comp-col">
        <h3 class="mb-2.5 font-serif text-[1.05rem] font-normal text-text-primary">
          {t.col1Titre}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {leftCards.map((card) => (
            <div class="skill-flip">
              <div class="skill-flip-inner">
                <div class="skill-flip-front">
                  <span class="rounded-sm px-2.5 py-1 text-[13px] font-light text-text-body" style="border: 0.5px solid var(--color-border);">
                    {card.front}
                  </span>
                </div>
                <div class="skill-flip-back rounded-sm px-2.5 py-1">
                  {card.back}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right column -->
      <div class="comp-col">
        <div class="mb-2.5 flex items-center justify-between">
          <h3 class="font-serif text-[1.05rem] font-normal text-text-primary">
            {t.col2Titre}
          </h3>
          <div class="flex items-center gap-3 opacity-25">
            <!-- Claude (Anthropic mark) -->
            <svg width="18" height="18" viewBox="0 0 46 32" fill="currentColor" aria-label="Claude">
              <path d="M33.6 0H12.4C5.6 0 0 5.6 0 12.4v7.2C0 26.4 5.6 32 12.4 32h21.2C40.4 32 46 26.4 46 19.6v-7.2C46 5.6 40.4 0 33.6 0zm-4.1 22.7l-2.8-5.1h-7.4l-2.8 5.1h-3.4L23 6.4l9.9 16.3h-3.4zm-6.5-8h4.6L25.3 10l-2.3 4.7z"/>
            </svg>
            <!-- OpenAI / ChatGPT -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-label="ChatGPT">
              <path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.998 5.998 0 0 0-3.998 2.9 6.042 6.042 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
            </svg>
            <!-- Gemini (Google star) -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-label="Gemini">
              <path d="M12 0C6.176 0 2.402 4.256 1.073 6.898c-.329.654.447 1.275 1.012.808C4.32 5.837 7.603 4.174 12 4.174S19.68 5.837 21.915 7.706c.565.467 1.341-.154 1.012-.808C21.598 4.256 17.824 0 12 0zM12 24c5.824 0 9.598-4.256 10.927-6.898.329-.654-.447-1.275-1.012-.808C19.68 18.163 16.397 19.826 12 19.826S4.32 18.163 2.085 16.294c-.565-.467-1.341.154-1.012.808C2.402 19.744 6.176 24 12 24zM0 12c0 1.657.503 3.196 1.073 4.102.329.523 1.012.072 1.012-.595V8.493c0-.667-.683-1.118-1.012-.595C.503 8.804 0 10.343 0 12zm24 0c0-1.657-.503-3.196-1.073-4.102-.329-.523-1.012-.072-1.012.595v7.014c0 .667.683 1.118 1.012.595C23.497 15.196 24 13.657 24 12z"/>
            </svg>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {rightCards.map((card) => (
            <div class="skill-flip">
              <div class="skill-flip-inner">
                <div class="skill-flip-front">
                  <span class="rounded-sm px-2.5 py-1 text-[13px] font-light text-text-body" style="border: 0.5px solid var(--color-border);">
                    {card.front}
                  </span>
                </div>
                <div class="skill-flip-back rounded-sm px-2.5 py-1">
                  {card.back}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skill-flip {
    perspective: 600px;
    display: inline-block;
    cursor: pointer;
  }

  .skill-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hover flip on pointer devices */
  @media (hover: hover) {
    .skill-flip:hover .skill-flip-inner {
      transform: rotateY(180deg);
    }
  }

  /* Tap flip on touch */
  .skill-flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .skill-flip-front,
  .skill-flip-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .skill-flip-front {
    position: relative;
  }

  .skill-flip-back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
    background: var(--color-text-secondary);
    color: var(--color-bg-primary);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 6px;
  }
</style>

<script>
  import { inView } from "motion";

  const cols = document.querySelectorAll<HTMLElement>(".comp-col");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced && cols.length) {
    cols.forEach((col) => {
      col.style.opacity = "0";
      col.style.transform = "translateY(20px)";
      col.style.transition = "opacity 0.6s ease, transform 0.6s ease";
    });

    inView("#competences-cols", () => {
      cols.forEach((col, i) => {
        setTimeout(() => {
          col.style.opacity = "1";
          col.style.transform = "translateY(0)";
        }, i * 100);
      });
    }, { amount: 0.2 });
  }

  // Touch: toggle flip on tap
  if (window.matchMedia("(pointer: coarse)").matches) {
    document.querySelectorAll<HTMLElement>(".skill-flip-inner").forEach((inner) => {
      inner.parentElement?.addEventListener("click", () => {
        inner.classList.toggle("flipped");
      });
    });
  }
</script>
