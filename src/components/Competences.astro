---
import type { Translations } from "../i18n/fr";

interface Props {
  t: Translations["competences"];
}

const { t } = Astro.props;
const leftCards = t.col1;
const rightCards = t.col2;
---

<section id="competences" style="scroll-margin-top: 70px;">
  <!-- Separator -->
  <div class="mx-auto max-w-[768px] px-8 max-md:px-6">
    <div class="h-px bg-border" />
  </div>

  <div class="mx-auto max-w-[768px] px-8 max-md:px-6 py-10">
    <h2 class="sr-only">{t.srTitre}</h2>

    <div aria-hidden="true" class="mb-6 text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-dark">
      {t.titre}
    </div>

    <div class="grid grid-cols-2 gap-8 max-md:grid-cols-1" id="competences-cols">
      <!-- Left column -->
      <div class="comp-col">
        <h3 class="mb-2.5 font-serif text-[1.05rem] font-normal text-text-primary">
          {t.col1Titre}
        </h3>
        <div class="flex flex-wrap gap-1.5">
          {leftCards.map((card) => (
            <div class="skill-flip">
              <div class="skill-flip-inner">
                <div class="skill-flip-front">
                  <span class="rounded-sm px-2.5 py-1 text-[13px] font-light text-text-body" style="border: 0.5px solid var(--color-border);">
                    {card.front}
                  </span>
                </div>
                <div class="skill-flip-back rounded-sm px-2.5 py-1">
                  {card.back}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right column -->
      <div class="comp-col">
        <div class="mb-2.5 flex items-center justify-between">
          <h3 class="font-serif text-[1.05rem] font-normal text-text-primary">
            {t.col2Titre}
          </h3>
          <div class="flex items-center gap-2 opacity-30">
            <!-- Claude -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M17.153 4.428c-.186-.098-.39-.04-.486.134l-5.04 9.217c-.09.163-.05.352.107.46.157.107.378.07.493-.08L17.267 4.9c.108-.163.072-.368-.114-.473z" fill="currentColor"/><path d="M12.397 7.398c-.186-.098-.39-.04-.486.134L7.735 15.95c-.09.163-.05.352.107.46.157.107.378.07.493-.08l4.176-8.46c.108-.163.072-.368-.114-.473z" fill="currentColor"/><path d="M7.64 10.368c-.186-.098-.39-.04-.486.134l-2.91 5.324c-.09.163-.05.352.107.46.157.107.378.07.493-.08l2.91-5.365c.108-.163.072-.368-.114-.473z" fill="currentColor"/></svg>
            <!-- ChatGPT -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.998 5.998 0 0 0-3.998 2.9 6.042 6.042 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
            <!-- Gemini -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 3.6c2.903 0 5.41 1.672 6.627 4.103C16.41 5.272 13.903 3.6 12 3.6S7.59 5.272 5.373 7.703C6.59 5.272 9.097 3.6 12 3.6zm0 16.8c-2.903 0-5.41-1.672-6.627-4.103C7.59 18.728 10.097 20.4 12 20.4s4.41-1.672 6.627-4.103C17.41 18.728 14.903 20.4 12 20.4z"/></svg>
            <!-- Git -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.546 10.93L13.067.452c-.604-.603-1.582-.603-2.188 0L8.708 2.627l2.76 2.76c.645-.215 1.379-.07 1.889.441.516.515.658 1.258.438 1.9l2.66 2.66c.645-.222 1.387-.078 1.9.435.72.72.72 1.884 0 2.604-.72.719-1.885.719-2.604 0-.538-.536-.67-1.32-.4-1.978l-2.48-2.48v6.53c.175.087.34.202.487.348.72.72.72 1.884 0 2.604-.72.719-1.886.719-2.604 0-.72-.72-.72-1.885 0-2.604.177-.177.381-.312.602-.4V9.89c-.222-.09-.425-.223-.6-.4-.545-.544-.676-1.338-.396-2.003L7.636 4.86.45 12.044c-.603.604-.603 1.582 0 2.186l10.48 10.477c.604.604 1.582.604 2.186 0l10.43-10.43c.605-.603.605-1.582 0-2.187"/></svg>
            <!-- Cloudflare -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16.51 15.93l.24-1.2c.06-.32-.02-.63-.22-.87-.2-.24-.5-.38-.82-.4l-8.82-.11c-.05 0-.1-.03-.12-.07-.03-.04-.03-.1-.01-.14.04-.1.14-.16.25-.17l8.92-.11c1.07-.06 2.23-.93 2.64-1.97l.52-1.34c.03-.07.03-.15 0-.22C18.44 6.11 15.46 3.6 11.89 3.6c-3.24 0-5.99 2.08-6.99 4.98-.62-.47-1.4-.72-2.24-.62C1.34 8.13.33 9.3.19 10.63c-.07.59.03 1.15.24 1.64C.17 12.28 0 12.62 0 12.99c0 .05 0 .1.01.15.13 1.57 1.45 2.79 3.04 2.79h13.11c.11 0 .21-.07.25-.17l.1-.23z"/><path d="M19.35 9.06c-.09 0-.18 0-.27.01-.05 0-.1.03-.13.08l-.35 1.12c-.06.32.02.63.22.87.2.24.5.38.82.4l1.74.1c.05 0 .1.03.12.07.03.04.03.1.01.14-.04.1-.14.16-.25.17l-1.82.1c-1.07.06-2.23.93-2.64 1.97l-.14.37c-.02.06.02.12.09.12h5.79c.07 0 .13-.04.15-.11.19-.64.3-1.32.3-2.03 0-1.81-1.47-3.28-3.28-3.28z"/></svg>
          </div>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {rightCards.map((card) => (
            <div class="skill-flip">
              <div class="skill-flip-inner">
                <div class="skill-flip-front">
                  <span class="rounded-sm px-2.5 py-1 text-[13px] font-light text-text-body" style="border: 0.5px solid var(--color-border);">
                    {card.front}
                  </span>
                </div>
                <div class="skill-flip-back rounded-sm px-2.5 py-1">
                  {card.back}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skill-flip {
    perspective: 600px;
    display: inline-block;
    cursor: pointer;
  }

  .skill-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hover flip on pointer devices */
  @media (hover: hover) {
    .skill-flip:hover .skill-flip-inner {
      transform: rotateY(180deg);
    }
  }

  /* Tap flip on touch */
  .skill-flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .skill-flip-front,
  .skill-flip-back {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .skill-flip-front {
    position: relative;
  }

  .skill-flip-back {
    position: absolute;
    inset: 0;
    transform: rotateY(180deg);
    background: var(--color-text-secondary);
    color: var(--color-bg-primary);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    line-height: 1;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 6px;
  }
</style>

<script>
  import { inView } from "motion";

  const cols = document.querySelectorAll<HTMLElement>(".comp-col");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced && cols.length) {
    cols.forEach((col) => {
      col.style.opacity = "0";
      col.style.transform = "translateY(20px)";
      col.style.transition = "opacity 0.6s ease, transform 0.6s ease";
    });

    inView("#competences-cols", () => {
      cols.forEach((col, i) => {
        setTimeout(() => {
          col.style.opacity = "1";
          col.style.transform = "translateY(0)";
        }, i * 100);
      });
    }, { amount: 0.2 });
  }

  // Touch: toggle flip on tap
  if (window.matchMedia("(pointer: coarse)").matches) {
    document.querySelectorAll<HTMLElement>(".skill-flip-inner").forEach((inner) => {
      inner.parentElement?.addEventListener("click", () => {
        inner.classList.toggle("flipped");
      });
    });
  }
</script>
