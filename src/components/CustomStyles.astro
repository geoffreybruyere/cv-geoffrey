---
import '@fontsource-variable/inter';
import '@fontsource-variable/montserrat';
import '@fontsource/cinzel/700.css';
import '@fontsource/cinzel/400.css';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Montserrat Variable';

    /* Charte "L'Aube sur la Roche" */
    --color-bleu-abyssal: 15 23 42;       /* #0F172A */
    --color-or-alpin: 235 162 64;          /* #EBA240 */
    --color-blanc-brume: 248 250 252;      /* #F8FAFC */
    --color-gris-ardoise: 100 116 139;     /* #64748B */
    --color-vert-lichen: 51 65 85;         /* #334155 */

    --aw-color-primary: rgb(235 162 64);
    --aw-color-secondary: rgb(210 140 50);
    --aw-color-accent: rgb(235 162 64);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(51 65 85);
    --aw-color-text-muted: rgb(100 116 139);
    --aw-color-bg-page: rgb(248 250 252);

    --aw-color-bg-page-dark: rgb(15 23 42);

    ::selection {
      background-color: rgb(235 162 64 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Montserrat Variable';

    --aw-color-primary: rgb(235 162 64);
    --aw-color-secondary: rgb(210 140 50);
    --aw-color-accent: rgb(235 162 64);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(15 23 42);

    ::selection {
      background-color: rgb(235 162 64 / 30%);
      color: snow;
    }
  }
</style>
