---
import { Mail, Download, Copy } from "@lucide/astro";
---

<footer id="contact">
  <!-- Separator -->
  <div class="mx-auto max-w-[768px] px-8 max-md:px-6">
    <div class="h-px bg-border" />
  </div>

  <div class="mx-auto max-w-[768px] px-8 max-md:px-6 pt-8 pb-12">
    <div class="flex items-start justify-between max-md:flex-col max-md:gap-8" id="footer-content">

      <!-- Left — Contact info -->
      <div class="footer-col">
        <p class="mb-1.5 font-serif text-base font-normal text-text-primary">Geoffrey Bruyère</p>
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-1.5">
            <span class="text-[11px] font-light text-text-secondary">geoffreybruyere@gmail.com</span>
            <button type="button" data-copy="geoffreybruyere@gmail.com" aria-label="Copier l'email" class="copy-btn text-text-secondary/50 hover:text-text-primary transition-colors cursor-pointer">
              <Copy size={12} strokeWidth={1.5} />
            </button>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-[11px] font-light text-text-secondary">(+33)6 27 40 18 91</span>
            <button type="button" data-copy="+33627401891" aria-label="Copier le numéro" class="copy-btn text-text-secondary/50 hover:text-text-primary transition-colors cursor-pointer">
              <Copy size={12} strokeWidth={1.5} />
            </button>
          </div>
          <span class="text-[11px] font-light text-text-secondary">Aix-en-Provence · Paris · Monde</span>
          <span class="text-[11px] font-light text-text-secondary">Bilingue anglais / français</span>
        </div>
      </div>

      <!-- Right — CTAs -->
      <div class="footer-col flex flex-col gap-2 items-end max-md:items-stretch">
        <!-- CTA primary -->
        <a
          href="mailto:geoffreybruyere@gmail.com"
          class="inline-flex w-[200px] items-center justify-center gap-2 rounded-sm px-4.5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.1em] transition-opacity hover:opacity-80 max-md:w-full"
          style="background: #FEFE7D; color: #141210;"
        >
          <Mail size={16} strokeWidth={1.5} />
          Me contacter
        </a>

        <!-- CTA secondary -->
        <a
          href="/geoffrey-bruyere-cv.pdf"
          download
          class="inline-flex w-[200px] items-center justify-center gap-2 rounded-sm px-4.5 py-2.5 text-[11px] font-semibold uppercase tracking-[0.1em] text-text-primary transition-opacity hover:opacity-80 max-md:w-full"
          style="border: 0.5px solid var(--color-border);"
        >
          <Download size={16} strokeWidth={1.5} />
          1-pager
        </a>
      </div>

    </div>
    <!-- Copyright centered -->
    <p class="mt-8 text-center text-[11px] font-light text-text-secondary/55">&copy; Geoffrey Bruyère &middot; Vibe-coded with &lt;3</p>
  </div>
</footer>

<script>
  import { inView } from "motion";

  const cols = document.querySelectorAll<HTMLElement>(".footer-col");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced && cols.length) {
    cols.forEach((col) => {
      col.style.opacity = "0";
      col.style.transform = "translateY(12px)";
      col.style.transition = "opacity 0.5s ease, transform 0.5s ease";
    });

    inView("#footer-content", () => {
      cols.forEach((col, i) => {
        setTimeout(() => {
          col.style.opacity = "1";
          col.style.transform = "translateY(0)";
        }, i * 100);
      });
    }, { amount: 0.2 });
  }

  // Copy buttons
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const svg = btn.querySelector("svg");
      if (svg) {
        svg.style.color = "var(--color-accent-dark)";
        setTimeout(() => { svg.style.color = ""; }, 1200);
      }
    });
  });
</script>
