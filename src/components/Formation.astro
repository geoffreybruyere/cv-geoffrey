---
const formations = [
  { year: "2017", school: "ESCP / Institut Français de la Mode", diploma: "Accélérateur Mode & Luxe · IFM Labels", city: "Paris" },
  { year: "2010", school: "Bosphore University", diploma: "MBA Program", city: "Istanbul" },
  { year: "2006", school: "Mines-Télécom Business School", diploma: "MSc in Management", city: "Paris" },
  { year: "2004", school: "CPGE Lycée Albert Schweitzer", diploma: "Maths Sup / Maths Spé", city: "Mulhouse" },
];
---

<section id="formation" style="scroll-margin-top: 70px;">
  <!-- Separator -->
  <div class="mx-auto max-w-[768px] px-8 max-md:px-6">
    <div class="h-px bg-border" />
  </div>

  <div class="mx-auto max-w-[768px] px-8 max-md:px-6 py-10">
    <!-- Screen reader heading -->
    <h2 class="sr-only">Formation</h2>

    <!-- Section label -->
    <div aria-hidden="true" class="mb-5 text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-dark">
      03 · Formation
    </div>

    <!-- Formation list -->
    <div id="formation-list" class="f-list">
      {formations.map((f, i) => (
        <div
          class="formation-row f-item flex items-baseline justify-between gap-4 py-3 max-md:flex-col max-md:gap-1"
          style={i < formations.length - 1 ? "border-bottom: 0.5px solid var(--color-border);" : ""}
        >
          <span class="flex items-baseline gap-4 max-md:flex-col max-md:gap-0.5">
            <span class="font-serif text-[1.05rem] font-normal text-text-primary">{f.school}</span>
            <span class="font-light text-text-body" style="font-size: 13px;">{f.diploma}</span>
          </span>
          <span class="shrink-0 font-light text-text-secondary max-md:text-left" style="font-size: 13px;">
            {f.city} · {f.year}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .f-item {
    transition: opacity 0.22s ease;
  }
  .f-list:hover .f-item {
    opacity: 0.49;
  }
  .f-list:hover .f-item:hover {
    opacity: 1;
  }
</style>

<script>
  import { inView } from "motion";

  const rows = document.querySelectorAll<HTMLElement>(".formation-row");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReduced && rows.length) {
    rows.forEach((row) => {
      row.style.opacity = "0";
      row.style.transform = "translateY(12px)";
      row.style.transition = "opacity 0.5s ease, transform 0.5s ease";
    });

    inView("#formation-list", () => {
      rows.forEach((row, i) => {
        setTimeout(() => {
          row.style.opacity = "1";
          row.style.transform = "translateY(0)";
          // Clear inline styles after animation so CSS :hover can work
          setTimeout(() => {
            row.style.removeProperty("opacity");
            row.style.removeProperty("transform");
            row.style.removeProperty("transition");
          }, 600);
        }, i * 80);
      });
    }, { amount: 0.2 });
  }
</script>
