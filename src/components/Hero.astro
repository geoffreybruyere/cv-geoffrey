---
import { Sun, Moon, Download, ChevronUp } from "@lucide/astro";
import type { Translations } from "../i18n/fr";
import type { Lang } from "../i18n/utils";

interface Props {
  t: Translations;
  lang: Lang;
}

const { t, lang } = Astro.props;
const navItems = [
  { label: t.nav.parcours, href: "#parcours" },
  { label: t.nav.competences, href: "#competences" },
  { label: t.nav.contact, href: "#contact" },
];
const langPrefix = lang === "en" ? "/en" : "";
const otherLangPrefix = lang === "en" ? "" : "/en";
---

<!-- ════════════════ NAV ════════════════ -->
<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="border-bottom: 0.5px solid transparent;"
>
      <div class="mx-auto flex max-w-[768px] items-center justify-between px-8 max-md:px-6 py-4">
        <div class="flex items-center">
          <!-- Back to top pill -->
          <button
            id="btn-top"
            type="button"
            aria-label={t.nav.ariaHaut}
            class="inline-flex items-center gap-0.5 rounded-sm border border-text-secondary/40 px-1 py-px text-text-secondary/60 opacity-0 pointer-events-none transition-all duration-200 hover:text-text-primary hover:border-text-primary cursor-pointer"
            style="background: color-mix(in srgb, var(--color-bg-primary) 80%, transparent);"
          >
            <ChevronUp size={12} strokeWidth={1.5} />
            <span class="text-[9px] font-normal uppercase tracking-[0.04em] max-sm:hidden">{t.nav.haut}</span>
          </button>

          <!-- Divider -->
          <div class="h-4 mx-3 opacity-0 transition-opacity duration-200" style="width: 0.5px; background: var(--color-border);" />

        <!-- Links — hidden on mobile -->
        <ul class="hidden md:flex items-center gap-6">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-[11px] font-medium uppercase tracking-[0.12em] text-text-secondary transition-all hover:text-text-primary border-b border-transparent hover:border-text-primary pb-0.5"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        </div>

        <!-- Spacer on mobile -->
        <div class="md:hidden" />

        <!-- Right controls -->
        <div class="flex items-center gap-2 max-md:gap-1.5 shrink-0">
          <!-- FR | EN toggle -->
          <div class="flex items-center gap-1.5">
            <a
              href={lang === "fr" ? "#" : "/"}
              class:list={[
                "text-[11px] uppercase tracking-[0.06em] border-b-[1.5px] pb-0.5 transition-all min-h-[44px] flex items-center",
                lang === "fr"
                  ? "text-text-primary font-semibold border-text-primary"
                  : "text-text-secondary font-normal border-transparent hover:text-text-primary cursor-pointer",
              ]}
            >
              FR
            </a>
            <a
              href={lang === "en" ? "#" : "/en/"}
              class:list={[
                "text-[11px] uppercase tracking-[0.06em] border-b-[1.5px] pb-0.5 transition-all min-h-[44px] flex items-center",
                lang === "en"
                  ? "text-text-primary font-semibold border-text-primary"
                  : "text-text-secondary font-normal border-transparent hover:text-text-primary cursor-pointer",
              ]}
            >
              EN
            </a>
          </div>

          <!-- Separator -->
          <div class="h-3.5 w-px bg-border" />

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            type="button"
            aria-label={t.nav.ariaDarkMode}
            class="relative h-5 w-9 cursor-pointer rounded-[10px] bg-bg-secondary transition-all duration-300 hover:opacity-75"
          >
            <span
              id="theme-thumb"
              class="absolute top-0.5 left-0.5 flex h-4 w-4 items-center justify-center rounded-full bg-bg-primary transition-all duration-300"
            >
              <Sun class="h-2.5 w-2.5 text-text-secondary transition-opacity duration-300 dark:opacity-0" />
              <Moon class="absolute h-2.5 w-2.5 text-text-primary opacity-0 transition-opacity duration-300 dark:opacity-100" />
            </span>
          </button>

          {lang === "fr" && (
            <>
              <div class="h-3.5 w-px bg-border max-sm:hidden" />
              <a
                href="/Geoffrey-Bruyere-CV.pdf"
                download
                aria-label={t.nav.ariaDownload}
                class="flex items-center justify-center min-w-[44px] min-h-[44px] text-text-secondary transition-colors hover:text-text-primary max-sm:hidden"
              >
                <Download size={16} strokeWidth={1.5} />
              </a>
            </>
          )}

        </div>
      </div>
    </nav>

<!-- ════════════════ HERO CONTAINER ════════════════ -->
<header id="hero-container" class="relative overflow-hidden">

  <!-- Canvas particles -->
  <canvas
    id="hero-particles"
    class="absolute top-0 left-0 z-[1] h-full w-full pointer-events-none"
    aria-hidden="true"
    role="presentation"
  ></canvas>

  <!-- Content layer -->
  <div class="relative z-[2]">

    <section class="pt-20 pb-18">
      <div class="mx-auto max-w-[768px] px-8 max-md:px-6">

        <!-- Identity row -->
        <div class="flex flex-row items-start gap-7 max-md:flex-col max-md:items-center max-md:text-center">
          <div class="photo-container h-[110px] w-[110px] shrink-0 overflow-hidden rounded-full transition-transform duration-300 hover:scale-[1.03]" style="background: var(--color-bg-primary);">
            <img src="/photo.jpg" alt={t.hero.nom} class="photo-img h-full w-full object-cover" />
          </div>

          <div class="flex-1 pt-1">
            <h1
              class="font-serif font-bold leading-[1.05] tracking-[-0.02em] text-text-primary transition-transform duration-300 hover:scale-[1.01]"
              style="font-size: clamp(2.5rem, 6vw, 3.5rem);"
            >
              Geoffrey<br />Bruyère
            </h1>

            <p class="mt-2.5 text-[0.95rem] font-normal tracking-[0.02em] text-text-primary">
              {t.hero.role}
            </p>

            <!-- Eyebrow -->
            <div class="eyebrow-row mt-3 flex items-center gap-2 max-md:justify-center cursor-default">
              <span class="eyebrow-badge inline-flex items-center gap-1.5 rounded-sm border border-border px-1.5 py-px text-[10px] font-medium uppercase tracking-[0.08em] text-text-secondary transition-all duration-200">
                <span class="inline-flex h-2 w-2 rounded-full bg-accent"></span>
                {t.hero.disponible}
              </span>
              <span class="eyebrow-loc text-[11px] font-medium uppercase tracking-[0.12em] text-text-secondary transition-colors duration-200">
                {t.hero.localisation}
              </span>
            </div>
          </div>
        </div>

        <!-- Statement -->
        <blockquote class="statement-block mt-10 border-l-[3px] border-accent pl-5" style="border-radius: 0;">
          <p class="statement-text text-[0.88rem] font-light leading-[1.75] text-text-body">
            {t.hero.statement1} <span class="font-normal text-text-emphasis">{t.hero.emphasis1}</span> {t.hero.mid1} <span class="font-normal text-text-emphasis">{t.hero.emphasis2}</span>{t.hero.statement1end}
          </p>
          <p class="statement-text mt-3 text-[0.88rem] font-light leading-[1.75] text-text-body">
            {t.hero.statement2start} <span class="font-normal text-text-emphasis">{t.hero.emphasis3}</span>.
          </p>
        </blockquote>

        <!-- KPI row -->
        <div class="kpi-list mt-8 flex flex-wrap items-center gap-y-2">
          <div class="kpi-item flex items-baseline gap-[5px] pr-4">
            <span class="stat-number font-serif text-[1.8rem] font-bold leading-none text-text-primary">{t.hero.stat1_nombre}</span>
            <span class="text-[11px] font-light text-text-secondary">{t.hero.stat1_label}</span>
          </div>
          <div class="h-[20px] w-px bg-border max-md:hidden" />
          <div class="kpi-item flex items-baseline gap-[5px] px-4 max-md:pl-0">
            <span class="stat-number font-serif text-[1.8rem] font-bold leading-none text-text-primary">{t.hero.stat2_nombre}</span>
            <span class="text-[11px] font-light text-text-secondary">{t.hero.stat2_label}</span>
          </div>
          <div class="h-[20px] w-px bg-border max-md:hidden" />
          <div class="kpi-item flex items-baseline gap-[5px] pl-4 max-md:pl-0">
            <span class="stat-number font-serif text-[1.8rem] font-bold leading-none text-text-primary">{t.hero.stat3_nombre}</span>
            <span class="text-[11px] font-light text-text-secondary">{t.hero.stat3_label}</span>
          </div>
        </div>
      </div>
    </section>

  </div>
</header>

<!-- ════════════════ STYLES ════════════════ -->
<style>
  .photo-img {
    mix-blend-mode: multiply;
    filter: brightness(1.15) contrast(0.95);
  }
  :global(.dark) .photo-img {
    mix-blend-mode: screen;
    filter: brightness(0.85) contrast(0.95);
  }

  :global(.statement-text) {
    transition: color 0.3s ease;
  }
  :global(.statement-block:hover .statement-text) {
    color: var(--color-text-primary) !important;
  }

  :global(.eyebrow-row:hover .eyebrow-badge) {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #484800;
  }
  :global(.eyebrow-row:hover .eyebrow-loc) {
    color: var(--color-text-primary);
  }

  :global(.kpi-item) {
    transition: opacity 0.22s ease;
  }
  :global(.kpi-list:hover .kpi-item) {
    opacity: 0.3;
  }
  :global(.kpi-list:hover .kpi-item:hover) {
    opacity: 1;
  }

</style>

<!-- ════════════════ SCRIPTS ════════════════ -->
<script>
  const nav = document.getElementById("site-nav");
  const toggle = document.getElementById("theme-toggle");
  const thumb = document.getElementById("theme-thumb");

  // ── Back to top ──
  document.getElementById("btn-top")?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // ── Dark mode toggle ──
  function applyDarkUI(isDark: boolean) {
    if (!toggle || !thumb) return;
    if (isDark) {
      toggle.classList.remove("bg-bg-secondary");
      toggle.classList.add("bg-accent");
      thumb.classList.remove("left-0.5", "bg-bg-primary");
      thumb.classList.add("left-[18px]", "bg-[#141210]");
    } else {
      toggle.classList.remove("bg-accent");
      toggle.classList.add("bg-bg-secondary");
      thumb.classList.remove("left-[18px]", "bg-[#141210]");
      thumb.classList.add("left-0.5", "bg-bg-primary");
    }
  }

  applyDarkUI(document.documentElement.classList.contains("dark"));

  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    applyDarkUI(isDark);
  });

  // ── Nav backdrop on scroll ──
  const btnTop = document.getElementById("btn-top");
  const btnTopDivider = btnTop?.nextElementSibling as HTMLElement | null;

  function updateNav() {
    if (!nav) return;
    const scrolled = window.scrollY > 10;
    if (scrolled) {
      nav.classList.add("backdrop-blur-md");
      nav.style.backgroundColor = "color-mix(in srgb, var(--color-bg-primary) 80%, transparent)";
      nav.style.borderBottomColor = "var(--color-border)";
    } else {
      nav.classList.remove("backdrop-blur-md");
      nav.style.backgroundColor = "transparent";
      nav.style.borderBottomColor = "transparent";
    }
    if (btnTop) {
      btnTop.style.opacity = scrolled ? "1" : "0";
      btnTop.style.pointerEvents = scrolled ? "auto" : "none";
    }
    if (btnTopDivider) {
      btnTopDivider.style.opacity = scrolled ? "1" : "0";
    }
  }

  window.addEventListener("scroll", updateNav, { passive: true });
  updateNav();

  // ── Active nav link on scroll ──
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("#site-nav a[href^='#']");
  const sectionMap: { id: string; link: HTMLAnchorElement }[] = [];
  navLinks.forEach((link) => {
    const id = link.getAttribute("href")!.slice(1);
    sectionMap.push({ id, link });
  });

  function updateActiveLink() {
    const scrollY = window.scrollY + 100;
    const atBottom = (window.innerHeight + window.scrollY) >= (document.body.offsetHeight - 100);
    let activeId = "";
    if (atBottom) {
      activeId = "contact";
    } else {
      for (const { id } of sectionMap) {
        const section = document.getElementById(id);
        if (section && section.offsetTop <= scrollY) {
          activeId = id;
        }
      }
    }
    for (const { id, link } of sectionMap) {
      if (id === activeId) {
        link.style.color = "var(--color-text-primary)";
        link.style.borderBottom = "1.5px solid var(--color-text-primary)";
        link.style.paddingBottom = "2px";
      } else {
        link.style.color = "";
        link.style.borderBottom = "1.5px solid transparent";
        link.style.paddingBottom = "2px";
      }
    }
  }

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();

  // ── Particle canvas ──
  const canvas = document.getElementById("hero-particles") as HTMLCanvasElement;
  const container = document.getElementById("hero-container") as HTMLElement;
  const ctx = canvas?.getContext("2d");

  const hasHover = window.matchMedia("(hover: hover)").matches;
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  interface Dot {
    ox: number;
    oy: number;
    baseSize: number;
    size: number;
    baseOpacity: number;
  }

  let dots: Dot[] = [];
  let mouse = { x: -999, y: -999 };

  function createDots(w: number, h: number) {
    dots = [];
    const spacing = 10;
    for (let x = spacing / 2; x < w; x += spacing) {
      for (let y = spacing / 2; y < h; y += spacing) {
        const yRatio = y / h;
        const yFactor = 1 - yRatio * 0.7;
        if (Math.random() < 0.92 * yFactor) {
          const size = 1.17 * (0.4 + Math.random() * 0.6) * (0.4 + yFactor * 0.6);
          dots.push({
            ox: x,
            oy: y,
            baseSize: size,
            size: size,
            baseOpacity: 0.624 * (0.3 + yFactor * 0.7),
          });
        }
      }
    }
  }

  function resize() {
    if (!canvas || !ctx || !container) return;
    const rect = container.getBoundingClientRect();
    canvas.width = rect.width * 2;
    canvas.height = rect.height * 2;
    canvas.style.width = rect.width + "px";
    canvas.style.height = rect.height + "px";
    ctx.setTransform(2, 0, 0, 2, 0, 0);
    createDots(rect.width, rect.height);
  }

  function getDotColor(opacity: number): string {
    const isDark = document.documentElement.classList.contains("dark");
    return isDark
      ? "rgba(44,44,42," + opacity + ")"
      : "rgba(172,172,170," + opacity + ")";
  }

  function draw() {
    if (!ctx || !canvas) return;
    const w = canvas.width / 2;
    const h = canvas.height / 2;
    ctx.clearRect(0, 0, w, h);
    const radius = 105;

    for (let i = 0; i < dots.length; i++) {
      const d = dots[i];
      const dx = d.ox - mouse.x;
      const dy = d.oy - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < radius) {
        const factor = dist / radius;
        const target = d.baseSize * factor * factor;
        d.size += (target - d.size) * 0.14;
      } else {
        d.size += (d.baseSize - d.size) * 0.07;
      }

      if (d.size > 0.08) {
        const opacity = d.baseOpacity * (d.size / d.baseSize);
        ctx.beginPath();
        ctx.arc(d.ox, d.oy, d.size, 0, Math.PI * 2);
        ctx.fillStyle = getDotColor(opacity);
        ctx.fill();
      }
    }
    requestAnimationFrame(draw);
  }

  if (hasHover && !prefersReduced && canvas && ctx && container) {
    container.addEventListener("mousemove", (e) => {
      const rect = container.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });

    container.addEventListener("mouseleave", () => {
      mouse.x = -999;
      mouse.y = -999;
    });

    resize();
    draw();
    window.addEventListener("resize", resize);
  }
</script>
