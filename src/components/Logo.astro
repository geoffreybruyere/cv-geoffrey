<div class="flex items-center gap-2.5 self-center ml-2 rtl:ml-0 rtl:mr-2">
  <!-- Logo SVG — montagne géométrique + étoile 4 branches -->
  <svg viewBox="0 0 200 240" class="w-8 h-10 md:w-7 md:h-9" fill="currentColor" aria-hidden="true">
    <!-- Étoile 4 branches au sommet -->
    <path d="M100 0 C100 18, 108 24, 116 24 C108 24, 100 30, 100 48 C100 30, 92 24, 84 24 C92 24, 100 18, 100 0Z" />
    <!-- Triangle principal (montagne — face gauche sombre) -->
    <polygon points="100,60 20,210 100,180" fill="currentColor" />
    <!-- Triangle (face droite — arête plus claire) -->
    <polygon points="100,60 180,210 100,180" fill="currentColor" opacity="0.7" />
    <!-- Face base gauche (ombre) -->
    <polygon points="20,210 100,180 120,210" fill="currentColor" opacity="0.55" />
    <!-- Contour arête droite (trait fin) -->
    <line x1="100" y1="60" x2="180" y2="210" stroke="currentColor" stroke-width="3" fill="none" opacity="0.3" />
  </svg>
  <!-- Texte CORE SUMMIT en Cinzel -->
  <span
    class="whitespace-nowrap text-[18px] md:text-[16px] text-bleu-abyssal"
    style="font-family: 'Cinzel', serif; letter-spacing: 0.2em;"
  ><span style="font-weight: 700;">CORE</span> <span style="font-weight: 400;">SUMMIT</span></span>
</div>
