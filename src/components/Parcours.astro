---
import type { Translations } from "../i18n/fr";

interface Props {
  t: Translations["parcours"];
}

const { t } = Astro.props;
const stations = t.stations;
const stationPositions = [12, 38, 65, 90]; // desktop
const stationPositionsMobile = [5, 30, 58, 85]; // mobile — even spacing
const p = t.panels;
---

<section id="parcours" style="scroll-margin-top: 70px;">

  <!-- ══════ Sticky: label + timeline ══════ -->
  <div
    class="sticky top-[52px] z-30 pb-4 pt-8"
    style="background: color-mix(in srgb, var(--color-bg-primary) 95%, transparent); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);"
  >
    <div class="mx-auto max-w-[768px] px-8 max-md:px-6">

      <!-- Label + hint -->
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-accent-dark">
          {t.titre}
        </h2>
        <span
          id="scroll-hint"
          class="text-[11px] font-light text-text-secondary transition-opacity duration-500"
        >
          {t.scrollHint}
        </span>
      </div>

      <!-- Timeline -->
      <div class="relative h-[90px] max-sm:h-[42px] max-sm:overflow-hidden">
        <!-- Base line -->
        <div class="absolute top-[4px] left-0 right-0 h-[3px] rounded-full bg-border" />
        <!-- Progress line -->
        <div
          id="timeline-progress"
          class="absolute top-[4px] left-0 h-[3px] rounded-full bg-accent"
          style="width: 0%; transition: width 0.5s cubic-bezier(0.25,0.1,0.25,1);"
        />

        <!-- Stations -->
        {stations.map((s, i) => (
          <button
            type="button"
            class="station-btn absolute flex flex-col items-start cursor-pointer transition-all duration-200 hover:brightness-75"
            style={`left: ${stationPositions[i]}%;`}
            data-station={i}
            data-mobile-left={stationPositionsMobile[i]}
          >
            <span
              id={`dot-${i}`}
              class="relative -left-[5px] block h-[11px] w-[11px] rounded-full bg-border transition-all duration-300"
            />
            <span class="mt-1.5 max-sm:mt-1 flex items-center gap-1.5 whitespace-nowrap text-[11px] max-sm:text-[8px] uppercase tracking-[0.1em] text-text-secondary transition-colors duration-300" id={`date-${i}`}>
              {s.year}
              {s.duration && (
                <span class="text-[10px] max-sm:hidden font-light normal-case tracking-[0.04em] text-text-secondary/50">· {s.duration}</span>
              )}
            </span>
            <span class={`whitespace-nowrap font-serif text-base max-sm:hidden ${s.nameWeight} text-text-secondary transition-colors duration-300`} id={`name-${i}`}>
              {s.name}
            </span>
            <span class="mt-0.5 flex items-center gap-1.5 whitespace-nowrap text-[11px] font-light text-text-secondary max-md:hidden">
              {s.role}
              {s.badges.map((b: string) => (
                <span class="inline-block rounded-sm border border-border px-1 py-px text-[9px] font-normal uppercase tracking-[0.04em] text-text-secondary/70">
                  {b}
                </span>
              ))}
            </span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ══════ Stacking panels ══════ -->
  <div class="mx-auto max-w-[768px] px-8 max-md:px-6 mt-6">

    <!-- Panel 0: Core Summit -->
    <div id="panel-0" class="panel-stack" data-index="0">
      <div style="border-top: 0.5px solid var(--color-border);" class="pt-5">
        <!-- Header -->
        <div class="flex items-baseline justify-between mb-3 max-md:flex-wrap max-md:gap-1">
          <div class="flex items-baseline gap-2">
            <span class="font-serif text-[1.2rem] font-bold text-text-primary">{p.coresummit.titre}</span>
            <span class="panel-role text-[13px] font-medium text-text-secondary">{p.coresummit.role}</span>
            <span class="panel-badge inline-block rounded-sm border border-border px-1 py-px text-[9px] font-normal uppercase tracking-[0.04em] text-text-secondary/70">{p.coresummit.badge}</span>
            <a href="https://www.coresummit.fr/" target="_blank" rel="noopener noreferrer" aria-label={p.coresummit.ariaLink} class="inline-flex items-center ml-0.5 text-text-secondary opacity-50 hover:opacity-100 transition-opacity"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg></a>
          </div>
          <span class="text-[11px] uppercase tracking-[0.1em] text-text-secondary max-md:text-[9px]">{p.coresummit.date}</span>
        </div>
        <!-- Intro -->
        <p class="text-[13px] font-normal leading-[1.65] text-text-emphasis">
          {p.coresummit.intro}
        </p>
        <!-- Detail -->
        <div class="mt-4 border-l-[1.5px] border-border pl-3">
          <p class="text-[13px] font-light leading-[1.6] text-text-body">
            {p.coresummit.detail1}
          </p>
          <p class="mt-2 text-[13px] font-light leading-[1.6] text-text-body">
            {p.coresummit.detail2}
          </p>
        </div>
      </div>
    </div>

    <!-- Sentinel 1 — placed after panel 0, triggers panel 1 -->
    <div id="sentinel-1" class="h-4" />
    <!-- Panel 1: Voyage Privé -->
    <div id="panel-1" class="panel-stack" data-index="1">
      <div style="border-top: 0.5px solid var(--color-border);" class="pt-5">
        <!-- Header -->
        <div class="flex items-baseline justify-between mb-3 max-md:flex-wrap max-md:gap-1">
          <div class="flex items-baseline gap-2">
            <span class="font-serif text-[1.2rem] font-bold text-text-primary">{p.voyageprive.titre}</span>
            <span class="panel-role text-[13px] font-medium text-text-secondary">{p.voyageprive.role}</span>
            <span class="panel-badge inline-block rounded-sm border border-border px-1 py-px text-[9px] font-normal uppercase tracking-[0.04em] text-text-secondary/70">{p.voyageprive.badge}</span>
            <a href="https://www.voyage-prive.com/" target="_blank" rel="noopener noreferrer" aria-label={p.voyageprive.ariaLink} class="inline-flex items-center ml-0.5 text-text-secondary opacity-50 hover:opacity-100 transition-opacity"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg></a>
          </div>
          <span class="text-[11px] uppercase tracking-[0.1em] text-text-secondary max-md:text-[9px]">{p.voyageprive.date}</span>
        </div>
        <!-- Intro -->
        <p class="text-[13px] font-normal leading-[1.65] text-text-emphasis">
          {p.voyageprive.intro}
        </p>
        <!-- KPI sidebar + Grid -->
        <div class="mt-5 flex gap-6 max-md:flex-col">
          <!-- KPIs vertical -->
          <div class="kpi-group flex flex-col gap-3 shrink-0 max-md:flex-row max-md:flex-wrap max-md:gap-4">
            {p.voyageprive.kpis.map((k, i) => (
              <>
                {i > 0 && <div class="h-px w-full bg-border max-md:hidden" />}
                <div class="kpi-item flex flex-col items-center min-w-[60px]">
                  <span class="font-serif text-[1.3rem] font-bold leading-none text-text-primary">{k.v}</span>
                  <span class="mt-0.5 text-[11px] font-light uppercase tracking-[0.12em] text-text-secondary">{k.l}</span>
                </div>
              </>
            ))}
          </div>
          <!-- Grid -->
          <div class="bloc-group grid grid-cols-2 gap-x-6 gap-y-5 max-md:grid-cols-1">
            {p.voyageprive.blocs.map((b) => (
              <div class="bloc-item border-l-[1.5px] border-border pl-3">
                <span class="text-[11px] font-medium uppercase tracking-[0.1em] text-accent-dark">{b.label}</span>
                {b.text.split('\n').map((line) => (
                  <p class="mt-1 text-[13px] font-light leading-[1.6] text-text-body">{line}</p>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Sentinel 2 -->
    <div id="sentinel-2" class="h-4" />
    <!-- Panel 2: BonneGueule -->
    <div id="panel-2" class="panel-stack" data-index="2">
      <div style="border-top: 0.5px solid var(--color-border);" class="pt-5">
        <!-- Header -->
        <div class="flex items-baseline justify-between mb-3 max-md:flex-wrap max-md:gap-1">
          <div class="flex items-baseline gap-2">
            <span class="font-serif text-[1.2rem] font-bold text-text-primary">{p.bonnegueule.titre}</span>
            <span class="panel-role text-[13px] font-medium text-text-secondary">{p.bonnegueule.role}</span>
            <span class="panel-badge inline-block rounded-sm border border-border px-1 py-px text-[9px] font-normal uppercase tracking-[0.04em] text-text-secondary/70">{p.bonnegueule.badge}</span>
            <a href="https://bonnegueule.fr/" target="_blank" rel="noopener noreferrer" aria-label={p.bonnegueule.ariaLink} class="inline-flex items-center ml-0.5 text-text-secondary opacity-50 hover:opacity-100 transition-opacity"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg></a>
          </div>
          <span class="text-[11px] uppercase tracking-[0.1em] text-text-secondary max-md:text-[9px]">{p.bonnegueule.date}</span>
        </div>
        <!-- Intro -->
        <p class="text-[13px] font-normal leading-[1.65] text-text-emphasis">
          {p.bonnegueule.intro}
        </p>
        <!-- KPI sidebar + Grid -->
        <div class="mt-5 flex gap-6 max-md:flex-col">
          <!-- KPIs vertical -->
          <div class="kpi-group flex flex-col gap-3 shrink-0 max-md:flex-row max-md:flex-wrap max-md:gap-4">
            {p.bonnegueule.kpis.map((k, i) => (
              <>
                {i > 0 && <div class="h-px w-full bg-border max-md:hidden" />}
                <div class="kpi-item flex flex-col items-center min-w-[60px]">
                  <span class="font-serif text-[1.3rem] font-bold leading-none text-text-primary">{k.v}</span>
                  <span class="mt-0.5 text-[11px] font-light uppercase tracking-[0.12em] text-text-secondary">{k.l}</span>
                </div>
              </>
            ))}
          </div>
          <!-- Grid -->
          <div class="bloc-group grid grid-cols-2 gap-x-6 gap-y-5 max-md:grid-cols-1">
            {p.bonnegueule.blocs.map((b) => (
              <div class="bloc-item border-l-[1.5px] border-border pl-3">
                <span class="text-[11px] font-medium uppercase tracking-[0.1em] text-accent-dark">{b.label}</span>
                {b.text.split('\n').map((line) => (
                  <p class="mt-1 text-[13px] font-light leading-[1.6] text-text-body">{line}</p>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Sentinel 3 -->
    <!-- Bottom spacer -->
    <div class="h-8" />
  </div>
</section>

<style>
  .panel-stack {
    opacity: 0;
    transform: translateY(20px);
    max-height: 0;
    overflow: hidden;
    padding: 0;
    transition: opacity 0.5s ease, transform 0.5s ease, max-height 0.6s ease;
  }
  .panel-stack.visible {
    transform: translateY(0);
    max-height: 1200px;
    padding-bottom: 2.875rem;
  }
  .panel-stack.visible.active {
    opacity: 1;
  }
  .panel-stack.visible.dimmed {
    opacity: 0.15;
  }
  .panel-role, .panel-badge {
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .panel-stack:hover .panel-role {
    color: var(--color-text-primary);
  }
  .panel-stack:hover .panel-badge {
    color: var(--color-text-primary);
    border-color: var(--color-text-primary);
  }

  /* Effet frères — KPIs */
  .kpi-item, .bloc-item {
    transition: opacity 0.22s ease;
  }
  .kpi-group:hover .kpi-item {
    opacity: 0.35;
  }
  .kpi-group:hover .kpi-item:hover {
    opacity: 1;
  }
  /* Effet frères — Blocs descriptifs */
  .bloc-group:hover .bloc-item {
    opacity: 0.35;
  }
  .bloc-group:hover .bloc-item:hover {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .panel-stack {
      opacity: 1 !important;
      transform: none !important;
      max-height: none !important;
      overflow: visible !important;
      padding-bottom: 2.875rem !important;
      transition: none !important;
    }
    #scroll-hint { display: none; }
  }
</style>

<script>
  const progressLine = document.getElementById("timeline-progress") as HTMLElement;
  const scrollHint = document.getElementById("scroll-hint") as HTMLElement;
  const isMobile = window.innerWidth < 640;
  const progressStops = isMobile ? [5, 30, 58, 85] : [12, 38, 65, 90];

  // Reposition stations on mobile
  if (isMobile) {
    document.querySelectorAll<HTMLElement>(".station-btn").forEach((btn) => {
      const mobileLeft = btn.dataset.mobileLeft;
      if (mobileLeft) btn.style.left = mobileLeft + "%";
    });
  }

  let lastRevealed = -1;
  const isReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── Update timeline dots + progress ──
  // activeIdx = the focused panel
  function updateTimeline(activeIdx: number) {
    for (let i = 0; i <= 3; i++) {
      const dot = document.getElementById("dot-" + i);
      const name = document.getElementById("name-" + i);
      const date = document.getElementById("date-" + i);
      if (!dot || !name || !date) continue;

      if (i <= activeIdx) {
        // Active or past (before active)
        dot.style.backgroundColor = "var(--color-accent)";
        dot.style.boxShadow = i === activeIdx ? "0 0 0 3px rgba(254,254,125,0.25)" : "none";
        name.style.color = i === activeIdx ? "var(--color-text-primary)" : "var(--color-text-secondary)";
        date.style.color = i === activeIdx ? "var(--color-accent-dark)" : "var(--color-text-secondary)";
      } else {
        // After active — grey regardless of revealed state
        dot.style.backgroundColor = "var(--color-border)";
        dot.style.boxShadow = "none";
        name.style.color = "var(--color-text-secondary)";
        date.style.color = "var(--color-text-secondary)";
      }
    }
    // Progress bar follows the active panel
    progressLine.style.width = progressStops[activeIdx] + "%";
  }

  // ── Focus system ──
  let currentFocus = -1;

  function setFocus(activeIdx: number) {
    if (activeIdx === currentFocus) return;
    currentFocus = activeIdx;
    for (let i = 0; i <= 2; i++) {
      const p = document.getElementById("panel-" + i);
      if (!p || !p.classList.contains("visible")) continue;
      p.classList.remove("active", "dimmed");
      if (i === activeIdx) {
        p.classList.add("active");
      } else {
        p.classList.add("dimmed");
      }
    }
    updateTimeline(activeIdx);
  }

  function updateFocusOnScroll() {
    const viewportCenter = window.innerHeight * 0.45;
    let closestIdx = 0;
    let closestDist = Infinity;

    for (let i = 0; i <= 2; i++) {
      const p = document.getElementById("panel-" + i);
      if (!p || !p.classList.contains("visible")) continue;
      const rect = p.getBoundingClientRect();
      const panelCenter = rect.top + rect.height / 2;
      const dist = Math.abs(panelCenter - viewportCenter);
      if (dist < closestDist) {
        closestDist = dist;
        closestIdx = i;
      }
    }

    // Activate station 3 (Wavestone) briefly when scrolled past last panel
    const lastPanel = document.getElementById("panel-2");
    if (lastPanel && lastPanel.classList.contains("visible")) {
      const lastRect = lastPanel.getBoundingClientRect();
      if (lastRect.bottom < window.innerHeight * 0.4) {
        updateTimeline(3);
        return;
      }
    }

    setFocus(closestIdx);
  }

  // ── Reveal a panel + update timeline ──
  function revealPanel(index: number) {
    const panel = document.getElementById("panel-" + index);
    if (panel && !panel.classList.contains("visible")) {
      panel.classList.add("visible");
    }
    if (index > lastRevealed) {
      lastRevealed = index;
    }
    if (scrollHint) scrollHint.style.opacity = "0";
    setFocus(index); // this calls updateTimeline internally
  }

  // ── Click handler ──
  function goToStation(index: number) {
    const maxPanel = Math.min(index, 2);
    for (let i = 0; i <= maxPanel; i++) {
      revealPanel(i);
    }
    if (index <= 2) {
      setFocus(index);
    } else {
      // Station 3 (Wavestone) — no panel, just light up timeline
      setFocus(2);
      updateTimeline(3);
    }
    setTimeout(() => {
      const target = document.getElementById("panel-" + maxPanel);
      if (target) {
        const stickyEl = document.querySelector("#parcours .sticky") as HTMLElement;
        const stickyHeight = stickyEl ? stickyEl.offsetHeight : 0;
        const navHeight = 52;
        const offset = navHeight + stickyHeight + 16;
        const targetY = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top: targetY, behavior: "smooth" });
      }
    }, 100);
  }

  // ── Scroll-based reveal ──
  let ticking = false;
  let lastRevealTime = 0;
  const COOLDOWN = 700; // ms — wait for panel expand animation before checking next

  function checkReveal() {
    const now = Date.now();

    // Panel 0: reveal when sticky timeline is visible
    if (lastRevealed < 0) {
      const sticky = document.querySelector("#parcours .sticky");
      if (!sticky) return;
      const rect = sticky.getBoundingClientRect();
      if (rect.bottom > 0 && rect.top < window.innerHeight * 0.9) {
        revealPanel(0);
        lastRevealTime = now;
      }
      return;
    }

    // Cooldown: don't check next panel until previous has expanded
    if (now - lastRevealTime < COOLDOWN) return;

    // Panels 1-3: reveal when the corresponding sentinel enters viewport
    const nextIdx = lastRevealed + 1;
    if (nextIdx > 2) return;

    const sentinel = document.getElementById("sentinel-" + nextIdx);
    if (!sentinel) return;
    const sentinelRect = sentinel.getBoundingClientRect();

    // Sentinel must be in the top 80% of the viewport
    if (sentinelRect.top < window.innerHeight * 0.8 && sentinelRect.bottom > 0) {
      revealPanel(nextIdx);
      lastRevealTime = now;
    }
  }

  // ── Init ──
  if (isReduced) {
    for (let i = 0; i <= 2; i++) {
      const p = document.getElementById("panel-" + i);
      if (p) { p.classList.add("visible", "active"); }
    }
    lastRevealed = 2;
    updateTimeline(2);
  } else {
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          checkReveal();
          updateFocusOnScroll();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial check (delayed to let layout settle)
    setTimeout(checkReveal, 100);

    // Station click handlers
    document.querySelectorAll<HTMLElement>(".station-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = Number(btn.dataset.station);
        goToStation(idx);
      });
    });
  }
</script>
