---
interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;
const label = lang === 'en' ? 'Share' : 'Partager';
const copied = lang === 'en' ? 'Link copied!' : 'Lien copié !';
---

<div class="share-wrap" data-copied={copied}>

  <!-- État normal -->
  <div class="share-pill share-default">
    <svg width="11" height="11" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <circle cx="11" cy="3" r="1.5"/>
      <circle cx="3" cy="7" r="1.5"/>
      <circle cx="11" cy="11" r="1.5"/>
      <line x1="4.5" y1="7.5" x2="9.5" y2="3.5"/>
      <line x1="4.5" y1="7.5" x2="9.5" y2="10.5"/>
    </svg>
    <span>{label}</span>
  </div>

  <!-- État copié -->
  <div class="share-pill share-copied" aria-hidden="true">
    <svg width="11" height="11" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <polyline points="3,7 6,10 11,4"/>
    </svg>
    <span>{copied}</span>
  </div>

  <!-- Tooltip -->
  <div class="share-tooltip" aria-hidden="true">{copied}</div>

</div>

<style>
  .share-wrap {
    position: relative;
    display: inline-flex;
    cursor: pointer;
  }

  .share-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border: .5px solid var(--color-border);
    border-radius: 20px;
    padding: 4px 10px;
    transition: border-color .2s, opacity .15s;
  }

  .share-pill span {
    font-family: 'Figtree', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .share-pill svg {
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .share-pill:hover {
    border-color: var(--color-text-secondary);
  }

  /* État copié — caché par défaut */
  .share-copied {
    display: none;
  }
  .share-copied span {
    color: var(--color-text-primary);
  }
  .share-copied svg {
    color: var(--color-text-primary);
  }

  /* Active */
  .share-wrap.is-copied .share-default { display: none; }
  .share-wrap.is-copied .share-copied  { display: inline-flex; }

  /* Tooltip */
  .share-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #141210;
    color: #FCFCFA;
    font-family: 'Figtree', sans-serif;
    font-size: 9px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity .15s;
  }

  .share-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 4px solid transparent;
    border-top-color: #141210;
  }

  .share-wrap.is-copied .share-tooltip { opacity: 1; }
</style>

<script>
  document.querySelectorAll('.share-wrap').forEach(wrap => {
    wrap.addEventListener('click', async () => {
      const url = window.location.href;

      try {
        if (navigator.share && window.matchMedia('(pointer: coarse)').matches) {
          await navigator.share({ url, title: 'Geoffrey Bruyère' });
        } else {
          await navigator.clipboard.writeText(url);
        }
      } catch (e) {
        // Fallback silencieux
      }

      wrap.classList.add('is-copied');
      setTimeout(() => wrap.classList.remove('is-copied'), 1500);
    });
  });
</script>
