---
export interface Props {
  logo?: string;
  title?: string;
  description?: string;
  applicationNote?: string;
  ctaLabel?: string;
  ctaButtonText?: string;
  ctaHref?: string;
  eventDate?: string;
  eventPlaces?: string;
  countdownTarget?: string;
  speakersNote?: string;
  speakers?: { name: string; role: string }[];
  backgroundImage?: string;
}

const {
  title = 'Arriver dans la <strong class="blur-[2px] hover:blur-0 transition-all duration-700">brume.</strong><br/>Repartir avec une <strong>direction</strong>.',
  description = '3 jours en montagne pour <u>faire taire le bruit</u>, retrouver une <u>clarté radicale</u>, et <u>reconstruire le système</u> (posture, habitudes, organisation) qui garantit votre prochain palier.',
  applicationNote = 'Sur candidature uniquement.',
  ctaButtonText = 'Rejoignez la prochaine expédition',
  ctaHref = '#candidater',
  eventDate = 'Du 3 au 5 juillet 2026',
  eventPlaces = 'Limité à 8 dirigeants',
  countdownTarget = '2026-07-03',
  speakersNote = 'Par des entrepreneurs ayant créé des sociétés de 1 à 60 personnes',
  speakers = [
    { name: 'Boris DUDA', role: 'Executive Coach' },
    { name: 'Geoffrey BRUYERE', role: 'Entrepreneur' },
    { name: 'Jeanne LEGRAND', role: 'Guide en Moyenne Montagne' },
  ],
  backgroundImage = '/images/hero-bg.png',
} = Astro.props;
---

<section class="relative min-h-[88vh] flex flex-col not-prose">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img src={backgroundImage} alt="" class="w-full h-full object-cover object-[center_60%]" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-r from-bleu-abyssal/90 via-bleu-abyssal/65 to-bleu-abyssal/25"></div>
    <!-- Noise texture overlay -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E&quot;); background-repeat: repeat; background-size: 256px 256px;"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex flex-col flex-1 px-8 md:px-16 pt-10 pb-8">
    <!-- Hero text -->
    <div class="max-w-2xl mt-auto">
      <h1
        class="text-[2rem] md:text-[2.5rem] lg:text-[3rem] font-heading font-bold text-blanc-brume leading-tight mb-5 uppercase tracking-tight"
        set:html={title}
      />
      <p class="text-[17px] md:text-lg text-gray-200 leading-relaxed mb-3 max-w-xl" set:html={description} />
      <p class="text-[17px] md:text-[18px] text-gris-ardoise italic">{applicationNote}</p>
    </div>
  </div>

  <!-- Bottom bar — 3 colonnes -->
  <div class="relative z-10 border-t border-white/10" style="background: rgba(15,23,42,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
    <div class="px-8 md:px-16 py-5 flex flex-col md:flex-row md:items-center gap-6 md:gap-0">

      <!-- Col 1 : CTA + timer -->
      <div class="md:w-1/3 flex flex-col items-start justify-center gap-1.5">
        <a
          href={ctaHref}
          class="inline-block bg-or-alpin hover:bg-[#d4912e] text-bleu-abyssal font-medium text-[16px] tracking-[0.0625em] px-7 py-3.5 rounded-full transition-all whitespace-nowrap w-fit hover:shadow-[0_0_20px_rgba(235,162,64,0.35)]"
        >
          {ctaButtonText}
        </a>
        <span
          id="hero-countdown"
          class="text-or-alpin text-[14px] font-mono pl-1"
        ></span>
      </div>

      <!-- Col 2 : Date + places -->
      <div class="md:w-1/3 md:border-l md:border-white/15 md:pl-8 flex flex-col justify-center">
        <p class="text-blanc-brume font-bold text-[17px]">{eventDate}</p>
        <p class="text-or-alpin text-[14px] mt-0.5">{eventPlaces}</p>
      </div>

      <!-- Col 3 : Speakers -->
      <div class="md:w-1/3 md:border-l md:border-white/15 md:pl-8 flex flex-col justify-center">
        <p class="text-blanc-brume text-[14px] font-medium mb-1">
          {speakers.map((s, i) => (
            <span>
              <strong>{s.name}</strong> <span class="text-gris-ardoise">({s.role})</span>{i < speakers.length - 1 ? <span class="text-gris-ardoise mx-1.5">&middot;</span> : ''}
            </span>
          ))}
        </p>
        <p class="text-gris-ardoise text-[14px]">{speakersNote}</p>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ countdownTarget }}>
  function updateCountdown() {
    const target = new Date(countdownTarget + 'T00:00:00');
    const now = new Date();
    const diff = target - now;
    const el = document.getElementById('hero-countdown');
    if (!el) return;
    if (diff <= 0) { el.textContent = ''; return; }

    const totalSeconds = Math.floor(diff / 1000);
    const totalDays    = Math.floor(totalSeconds / 86400);
    const months       = Math.floor(totalDays / 30.44);
    const days         = Math.floor(totalDays % 30.44);
    const hours        = Math.floor((totalSeconds % 86400) / 3600);
    const minutes      = Math.floor((totalSeconds % 3600) / 60);
    const seconds      = totalSeconds % 60;

    const pad = (n) => String(n).padStart(2, '0');

    el.textContent = months > 0
      ? `dans ${months}m ${days}j ${pad(hours)}h ${pad(minutes)}min ${pad(seconds)}s`
      : `dans ${totalDays}j ${pad(hours)}h ${pad(minutes)}min ${pad(seconds)}s`;
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
