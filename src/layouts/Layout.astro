---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const { title = "Geoffrey Bruyere — CV", description = "CV personnel de Geoffrey Bruyere", lang = "fr" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts: Rufina + Figtree -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700&family=Rufina:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Inline script to prevent FOUC on dark mode -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Grain overlay -->
    <svg class="grain-svg" aria-hidden="true">
      <filter id="grain-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="4" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-filter)" />
    </svg>

    <style>
      .grain-svg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.10;
        mix-blend-mode: multiply;
      }
      :global(.dark) .grain-svg {
        mix-blend-mode: screen;
        opacity: 0.08;
      }
    </style>
  </body>
</html>
